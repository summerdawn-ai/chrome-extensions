{
  "manifest_version": 3,
  "name": "Substack Archive Enhancer",
  "version": "0.1.0",
  "description": "Adds archive and unarchive controls to supported Substack post pages.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "substack-archiver-content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "substack-archiver-page-script.js"
      ],
      "matches": [
        "https://*/*"
      ]
    }
  ]
}