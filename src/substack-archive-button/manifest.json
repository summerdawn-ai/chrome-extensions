{
  "manifest_version": 3,
  "name": "Substack Archive Button",
  "version": "1.0.0",
  "description": "Adds Archive and Unarchive buttons to Substack post pages.",
  "homepage_url": "https://github.com/summerdawn-ai/chrome-extensions",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://substack.com/*",
        "https://*.substack.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-script.js"
      ],
      "matches": [
        "https://substack.com/*",
        "https://*.substack.com/*"
      ]
    }
  ]
}
